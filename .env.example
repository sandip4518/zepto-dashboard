# Example .env for local development
# For Render / Neon you should set DATABASE_URL in the Render dashboard

DATABASE_URL=postgres://username:password@host:5432/dbname
# Optional: override SSL mode used by psycopg2 (defaults to 'require' when DATABASE_URL set)
# DB_SSLMODE=require

# OR specify individual connection variables for local dev:
# DB_HOST=localhost
# DB_NAME=zepto_SQL_Analysis
# DB_USER=postgres
# DB_PASS=your_password
# DB_PORT=5432
